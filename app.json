{
  "expo": {
    "name": "Meu Cartão",
    "slug": "controle-cartao",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F0F4F3"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "themeColor": "#0F766E",
      "backgroundColor": "#F0F4F3",
      "meta": {
        "apple-mobile-web-app-capable": "yes",
        "apple-mobile-web-app-status-bar-style": "default",
        "apple-mobile-web-app-title": "Meu Cartão"
      }
    },
    "plugins": [
      "expo-router"
    ],
    "android": {
      "package": "com.meucartao.app"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}